# ════════════════════════════════════════════════════════════════
#  MAMPOSTERA — Variables de Entorno
#  Copiar a frontend/.env.local y completar con valores reales.
#  NUNCA commitear este archivo con valores reales.
#  En producción: Infisical gestiona todos los secretos.
# ════════════════════════════════════════════════════════════════

# ── Infisical (bootstrap — se leen al arrancar el server) ────────
INFISICAL_CLIENT_ID=your-machine-identity-client-id
INFISICAL_CLIENT_SECRET=your-machine-identity-client-secret
INFISICAL_PROJECT_ID=your-project-id
INFISICAL_ENV=production

# ── Solana / Blockchain ─────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=testnet
NEXT_PUBLIC_RPC_ENDPOINT=https://api.testnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=MAMPoSTERA11111111111111111111111111111111
NEXT_PUBLIC_AUTHORITY_PUBKEY=YourWalletPublicKeyHere

# ── Civic KYC ─────────────────────────────────────────────────────
NEXT_PUBLIC_CIVIC_GATEKEEPER=ignREusXmGrscGNUesoU9mxfds9AiYTezUKex2PsZV6

# ── Privy Auth ────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_WEBHOOK_SECRET=your-privy-webhook-secret

# ── Sentry ────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=mampostera
SENTRY_PROJECT=mampostera-frontend

# ── PostHog ────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=phx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Crisp Chat ─────────────────────────────────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Stripe ────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── MoonPay ───────────────────────────────────────────────────────
MOONPAY_API_KEY=pk_test_xxx
MOONPAY_SECRET_KEY=sk_test_xxx
MOONPAY_WEBHOOK_SECRET=whsec_xxx

# ── Resend ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hola@mampostera.co

# ── Twilio ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Anthropic / Claude ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Firma.co ─────────────────────────────────────────────────────
FIRMA_API_KEY=your-firma-co-api-key
FIRMA_WEBHOOK_SECRET=your-firma-webhook-secret

# ── Cloudflare ───────────────────────────────────────────────────
CF_ZONE_ID=your-zone-id
CF_API_TOKEN=your-api-token
CF_TURNSTILE_SECRET=your-turnstile-secret

# ── Queue (Upstash QStash) ────────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGN=your-current-signing-key
QSTASH_NEXT_SIGN=your-next-signing-key

# ── App URL (para QStash callbacks) ──────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.mampostera.co

# ── Wompi / PSE Colombia (R5) ─────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_PRIVATE_KEY=prv_test_xxx
WOMPI_EVENTS_KEY=your-wompi-events-key
# ── Switchboard V2 (R4) ───────────────────────────────────────────────────────
SWITCHBOARD_FEED_PUBKEY=your-switchboard-aggregator-pubkey
# ── Helius (R6 — indexador en tiempo real) ────────────────────────────────────
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=your-helius-webhook-secret
# URL donde Helius enviará los eventos (configurar en dashboard.helius.xyz):
# HELIUS_WEBHOOK_URL=https://app.mampostera.co/api/webhooks/helius

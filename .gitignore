# ═══════════════════════════════════════════════
#  MAMPOSTERA — .gitignore
# ═══════════════════════════════════════════════

# Keypairs — NUNCA commitear
*.json
!package.json
!tsconfig*.json
!package-lock.json
!yarn.lock
*-keypair.json
id.json
wallet.json

# Secrets
.env
.env.local
.env.*

# Anchor / Solana / Rust
.anchor/
target/
**/*.so

# CRÍTICO: Cargo.lock generado con nightly (versión 4)
# incompatible con Rust stable — el CI lo regenera automáticamente
Cargo.lock

# Node
node_modules/
frontend/node_modules/

# Next.js
frontend/.next/
frontend/out/
frontend/build/

# Sistema
.DS_Store
Thumbs.db
*.log

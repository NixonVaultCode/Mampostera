{
  "compilerOptions": {
    "target":                     "es2020",
    "module":                     "commonjs",
    "lib":                        ["es2020"],
    "strict":                     true,
    "esModuleInterop":            true,
    "skipLibCheck":               true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":          true,
    "outDir":                     "dist",
    "baseUrl":                    ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "target", "frontend"],
  "ts-node": {
    "transpileOnly": true,
    "files":         true
  }
}
